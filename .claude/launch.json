{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python HTTP Server (Port 8000)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "Node.js HTTP Server (Port 3000)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "-p", "3000", "-c-1"],
      "port": 3000
    },
    {
      "name": "Vercel Dev Server (Port 3001)",
      "runtimeExecutable": "vercel",
      "runtimeArgs": ["dev", "--port", "3001"],
      "port": 3001
    }
  ]
}
